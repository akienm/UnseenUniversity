#!/bin/bash
# rescueclaude — the "everything's borked" recovery launcher.
#
# CONTRACT: must start Claude Code even when the DB is down/absent, our services
# are dead, our package won't import, or the repo dir is missing. It is the path
# back to a working system, so it depends on NOTHING of ours but the claude CLI.
# No DB check, no service check, no python import, no `set -e`.
#
# NO injected credentials. UU_HOME_DB_URL comes from the environment (bashrc /
# credential manager) or not at all — if it's absent, claude still starts so it
# can fix things. Baking a connection string in here would (a) defeat the
# start-even-without-the-DB contract and (b) commit a credential to the repo. Both no.

CC_TMUX_SESSION=akiendelllinux_cc_RESCUE
# Repo dir is overridable ONLY for hermetic chaos-testing of the recovery path;
# defaults to the real location. A read-only path select with a safe default —
# it cannot make the launch fail. (T-launcher-unfailable-recovery)
UU_DIR="${UU_RESCUE_DIR:-/home/akien/dev/src/UnseenUniversity}"
RECOVERY_NOTES=()

# Best-effort cd; fall back to HOME so claude still launches if the repo is gone.
cd "$UU_DIR" 2>/dev/null || cd "$HOME" 2>/dev/null || true

# Best-effort venv so CC's Bash subshells inherit it (venv python, pytest,
# editable package, cwd-independent imports). UNFAILABLE: every step is guarded so
# a missing venv / python3 / timeout — or any broken box — still reaches claude.
#   1. activate if present;
#   2. else TRY to create the venv SHELL (python3 -m venv — fast, offline). We
#      NEVER `pip install` here: a network install can hang for minutes and a hang
#      is a launch failure. The actual package rebuild is CC's job once started.
#   3. still absent -> record a note, reported to the terminal just before launch.
# Sets only VIRTUAL_ENV/PATH on activate — no credentials (cf. superclaude 401).
_venv="${UU_DIR}/.venv"
if [ ! -f "${_venv}/bin/activate" ] && command -v python3 >/dev/null 2>&1; then
  if command -v timeout >/dev/null 2>&1; then
    timeout 60 python3 -m venv "${_venv}" >/dev/null 2>&1 || true
  else
    python3 -m venv "${_venv}" >/dev/null 2>&1 || true
  fi
fi
if [ -f "${_venv}/bin/activate" ]; then
  # shellcheck disable=SC1090
  source "${_venv}/bin/activate" 2>/dev/null || true
else
  RECOVERY_NOTES+=("venv unavailable at ${_venv} (python3 missing or venv creation failed). CC is starting anyway — rebuild from inside, e.g.  python3 -m venv .venv && pip install -e .")
fi
# ── Wrapper flags (consumed here, never forwarded to claude) ──────────────────
# --new : start a FRESH RESCUE conversation instead of resuming the picker —
#         same display/remote-control name (still the RESCUE instance), just a new
#         conversation, so it boots with current tools, not a stale tool set.
# --1m  : use the 1M-token context window. Off by default. The control is the
#         CLAUDE_CODE_DISABLE_1M_CONTEXT env var, which .bashrc exports =1 for
#         session hygiene; --1m UNSETS it for this launch so the 1M window is
#         allowed. It does NOT touch the model — there is no "opus[1m]" model and
#         the [1m] suffix does not gate the context window; pick the model with
#         /model as usual. Opus 1M is auto-included on Max/Team/Enterprise (no
#         credit gate). (T-launcher-help-and-1m-flags)
# --help: print these wrapper flags, then claude's own --help.
# Flags may appear in any order; everything else is forwarded to claude.
RESUME_ARGS=(--resume "$CC_TMUX_SESSION")
PASS_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --new)  RESUME_ARGS=() ;;
    --1m)   unset CLAUDE_CODE_DISABLE_1M_CONTEXT ;;
    --help|-h)
      cat <<'HELP'
rescueclaude — the "everything's borked" recovery launcher.

  Wrapper flags (consumed by rescueclaude, NOT passed to claude):
    --new       Start a fresh RESCUE conversation instead of resuming the picker.
    --1m        Use the 1M-token context window (unsets the inherited
                CLAUDE_CODE_DISABLE_1M_CONTEXT=1 from .bashrc). Off by default.
                Does not change the model — pick it with /model. Opus 1M is
                auto-included on Max/Team/Enterprise.
    --help, -h  Show this message, then claude's own --help below.

  All other arguments are forwarded to claude.
──────────────────────────────────────────────────────────────────────────────
HELP
      exec claude --help
      ;;
    *) PASS_ARGS+=("$arg") ;;
  esac
done
set -- "${PASS_ARGS[@]}"

# Report anything we couldn't fix — best-effort, never blocks or fails the launch.
if [ "${#RECOVERY_NOTES[@]}" -gt 0 ]; then
  {
    echo ""
    echo "──────────────── rescueclaude: recovery notes ────────────────"
    for _n in "${RECOVERY_NOTES[@]}"; do echo "  ⚠ ${_n}"; done
    echo "──────────────────────────────────────────────────────────────"
    echo ""
  } >&2 || true
fi

exec claude --dangerously-skip-permissions "${RESUME_ARGS[@]}" -n "$CC_TMUX_SESSION" --remote-control "$CC_TMUX_SESSION" "$@"
