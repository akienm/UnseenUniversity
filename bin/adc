#!/usr/bin/env python3
"""adc — ADC management CLI bootstrap.

On first run: creates .venv, installs unseen_university, then delegates to agentctl.
On subsequent runs: delegates to agentctl directly.

Usage:
  ./bin/adc init [--instance <name>]
  ./bin/adc skills deploy
  ./bin/adc skills status
  ./bin/adc status
"""
import subprocess
import sys
from pathlib import Path

ADC_ROOT = Path(__file__).resolve().parent.parent
VENV_DIR = ADC_ROOT / ".venv"
_BIN = "Scripts" if sys.platform == "win32" else "bin"
_EXT = ".exe" if sys.platform == "win32" else ""
VENV_PYTHON   = VENV_DIR / _BIN / f"python{_EXT}"
VENV_AGENTCTL = VENV_DIR / _BIN / f"agentctl{_EXT}"


def _install(pip_args: list) -> None:
    """Run pip install inside the venv."""
    subprocess.run([str(VENV_PYTHON), "-m", "pip", "install"] + pip_args, check=True)


def _bootstrap() -> None:
    """Create venv and install ADC if not already set up."""
    if not VENV_DIR.exists():
        print(f"adc: first run — bootstrapping venv at {VENV_DIR}")
        try:
            subprocess.run(["uv", "venv", str(VENV_DIR)], check=True, cwd=ADC_ROOT)
            subprocess.run(
                ["uv", "pip", "install", "--python", str(VENV_PYTHON), "-e", str(ADC_ROOT)],
                check=True, cwd=ADC_ROOT,
            )
        except (subprocess.CalledProcessError, FileNotFoundError):
            subprocess.run([sys.executable, "-m", "venv", str(VENV_DIR)], check=True)
            _install(["-e", str(ADC_ROOT)])
        print("adc: bootstrap complete")
    elif not VENV_AGENTCTL.exists():
        print("adc: installing unseen_university into existing venv")
        try:
            subprocess.run(
                ["uv", "pip", "install", "--python", str(VENV_PYTHON), "-e", str(ADC_ROOT)],
                check=True, cwd=ADC_ROOT,
            )
        except (subprocess.CalledProcessError, FileNotFoundError):
            _install(["-e", str(ADC_ROOT)])


def _find_agentctl() -> "str | None":
    """Return path to agentctl: local venv first, then PATH."""
    import shutil
    if VENV_AGENTCTL.exists():
        return str(VENV_AGENTCTL)
    return shutil.which("agentctl")


def main() -> None:
    # If agentctl is already available (e.g., installed via TheIgors venv), use it.
    agentctl = _find_agentctl()
    if agentctl is None:
        _bootstrap()
        agentctl = _find_agentctl()
    if agentctl is None:
        print(f"ERROR: agentctl not found after bootstrap: {VENV_AGENTCTL}", file=sys.stderr)
        sys.exit(1)
    result = subprocess.run([agentctl] + sys.argv[1:])
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()
