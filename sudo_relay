#!/usr/bin/env python3
"""sudo_relay — sudoer relay daemon launcher.

Starts the sudoer_daemon.sh in a tmux session so Igor and other devices
can request privileged operations (apt install, etc.) without embedding
sudo in their own processes.

Usage:
  ./sudo_relay             # start daemon, attach current terminal to it
  ./sudo_relay --no-attach # start detached (for automation/shim use)
  ./sudo_relay --status    # print whether the daemon is running
  ./sudo_relay --stop      # kill the daemon session
  ./sudo_relay --help
"""

import subprocess
import sys
from pathlib import Path

from unseen_university.shim import BaseShim

UU_ROOT = Path(__file__).resolve().parent
DAEMON_SCRIPT = UU_ROOT / "unseen_university" / "devices" / "igor" / "tools" / "sudoer_daemon.sh"

TMUX_SESSION = "sudo-relay"


def _session_exists() -> bool:
    r = subprocess.run(["tmux", "has-session", "-t", TMUX_SESSION], capture_output=True)
    return r.returncode == 0


def _start_daemon(attach: bool = True) -> None:
    if not DAEMON_SCRIPT.exists():
        print(f"sudo_relay: daemon script not found at {DAEMON_SCRIPT}")
        sys.exit(1)
    BaseShim.spawn_foreground_session(
        TMUX_SESSION,
        ["bash", str(DAEMON_SCRIPT)],
        no_attach=not attach,
    )
    # Detached path only — exec above replaces the process in the attach path.
    print(f"sudo_relay: daemon started in tmux session '{TMUX_SESSION}' (detached)")


def _stop() -> None:
    if not _session_exists():
        print("sudo_relay: no running session")
        return
    subprocess.run(["tmux", "kill-session", "-t", TMUX_SESSION])
    print(f"sudo_relay: session '{TMUX_SESSION}' killed")


def _status() -> None:
    if _session_exists():
        print(f"sudo_relay: session '{TMUX_SESSION}' is running")
    else:
        print(f"sudo_relay: session '{TMUX_SESSION}' is NOT running")


def main() -> None:
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    if "--status" in args:
        _status()
        sys.exit(0)

    if "--stop" in args:
        _stop()
        sys.exit(0)

    attach = "--no-attach" not in args
    if _session_exists():
        if attach:
            BaseShim.spawn_foreground_session(TMUX_SESSION, [], no_attach=False)
        else:
            print(f"sudo_relay: session '{TMUX_SESSION}' already running")
    else:
        _start_daemon(attach=attach)


if __name__ == "__main__":
    main()
