#!/usr/bin/env python3
"""savestate — flush in-flight state to today's slate.

Usage:
  python run midstream "<hypothesis>"                  # mid-session flush
  python run close "<hypothesis>"                      # end-of-session flush + session_capture
  python run close-header "<date>" "<done>" "<next>"   # append session-close summary (SKILL Step 1)
"""
import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path

# Resolve the runtime home/root at module scope. The import is guarded so a flush
# never hard-fails outside the repo (recovery shell / cwd off-repo) — CP6: a
# savestate must always be able to write the slate. (The previous version called
# uu_home() at module scope while only importing it inside _cc_tools() — a NameError
# that broke EVERY `run close`/`midstream`/`close-header`.)
try:
    from unseen_university._uu_root import uu_home, uu_root
except Exception:  # package not importable — fall back, don't break the flush
    def uu_home() -> str:
        return str(Path.home() / ".unseen_university")

    def uu_root() -> str:
        return os.environ.get("UU_ROOT") or str(Path.home() / "dev/src/UnseenUniversity")

UU_HOME = Path(uu_home())


def _cc_tools() -> Path:
    if val := os.environ.get("CC_WORKFLOW_TOOLS", "").strip():
        return Path(val)
    # devlab/claudecode is the canonical tools dir (the old top-level path is retired).
    return Path(uu_root()) / "devlab" / "claudecode"

CC_TOOLS = _cc_tools()


def _save_availability_state() -> None:
    """Move CC.x availability flag from active to cachedstate (file semaphore pattern).

    Extract CC instance from CC_TMUX_SESSION env var (e.g., 'claude-cc.1' → CC.1).
    Before compact/rewind: move ~/.granny/available/CC.x.available.{true|false}
    to ~/.unseen_university/devices/cc_x/cachedstate/

    No file in active folder = implicitly unavailable during compaction.
    On next cycle, context-load will restore from cachedstate if it exists.
    """
    # Detect which CC instance from CC_TMUX_SESSION
    cc_session = os.environ.get("CC_TMUX_SESSION", "claude-main")
    cc_instance = "CC.0"  # default
    if "cc." in cc_session.lower():
        parts = cc_session.lower().split("cc.")
        if len(parts) > 1:
            cc_instance = f"CC.{parts[1].split('.')[0]}"

    granny_avail = Path.home() / ".granny" / "available"
    if not granny_avail.exists():
        return

    device_id = cc_instance.lower().replace(".", "_")  # 'CC.1' → 'cc_1'
    cachedstate = UU_HOME / "devices" / device_id / "cachedstate"
    cachedstate.mkdir(parents=True, exist_ok=True)

    # Move whichever file exists (.true or .false) to cachedstate
    for flag_file in granny_avail.glob(f"{cc_instance}.available.*"):
        dest = cachedstate / flag_file.name
        try:
            flag_file.rename(dest)
        except Exception:
            pass


def _slate_path() -> Path:
    # Canonical slate location is the dev-process memory store, not IGOR_HOME
    # (T-slate-location-canonical-devlab). Resolve through slate_store; fall back
    # to the same canonical literal if the package isn't importable (cwd outside
    # the repo) — never silently write to the old ~/.unseen_university/claudecode.
    try:
        from unseen_university import slate_store
        return slate_store.today_slate_path()
    except Exception:
        root = Path(os.environ.get("UU_ROOT") or Path.home() / "dev/src/UnseenUniversity")
        date_str = datetime.now().strftime("%Y%m%d")
        return root / "devlab" / "runtime" / "memory" / "slates" / f"{date_str}.slate.txt"


def _update_in_flight(hypothesis: str) -> None:
    """Write in_flight to slate — JSON or markdown depending on format."""
    slate = _slate_path()
    slate.parent.mkdir(parents=True, exist_ok=True)

    if slate.exists():
        try:
            data = json.loads(slate.read_text(encoding="utf-8"))
            # JSON slate: update in_flight field
            data["in_flight"] = [hypothesis] if hypothesis != "NONE" else []
            slate.write_text(json.dumps(data, indent=2), encoding="utf-8")
            return
        except json.JSONDecodeError:
            pass

    # Markdown slate (old format): append as before
    with slate.open("a", encoding="utf-8") as f:
        f.write(f"\n## In-flight: {hypothesis}\n")


def _close_header(date_str: str, done: str, nxt: str) -> None:
    """Append a session-close summary (Done/Next) to today's slate (SKILL Step 1)."""
    slate = _slate_path()
    slate.parent.mkdir(parents=True, exist_ok=True)
    with slate.open("a", encoding="utf-8") as f:
        f.write(f"\n## Session close {date_str}\nDone: {done}\nNext: {nxt}\n")


def main() -> None:
    mode = sys.argv[1] if len(sys.argv) > 1 else "midstream"

    if mode == "close-header":
        # python run close-header "<date>" "<done>" "<next>"
        date_str = sys.argv[2] if len(sys.argv) > 2 else datetime.now().strftime("%Y-%m-%d")
        done = sys.argv[3] if len(sys.argv) > 3 else ""
        nxt = sys.argv[4] if len(sys.argv) > 4 else ""
        _close_header(date_str, done, nxt)
        print(f"savestate (close-header): {date_str}")
        return

    hypothesis = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else "NONE"

    # Step 1: Save CC.x availability state (file semaphore → cachedstate)
    _save_availability_state()

    # Step 2: Flush in-flight to slate
    _update_in_flight(hypothesis)
    print(f"savestate ({mode}): {hypothesis}")

    if mode == "close" and CC_TOOLS and CC_TOOLS.exists():
        capture = CC_TOOLS / "session_capture.py"
        if capture.exists():
            result = subprocess.run(
                [sys.executable, str(capture)],
                capture_output=True, text=True
            )
            out = (result.stdout or "").strip()
            if out:
                print(out)
            if result.returncode != 0 and result.stderr:
                print(f"session_capture warning: {result.stderr[:300]}", file=sys.stderr)


if __name__ == "__main__":
    main()
