#!/usr/bin/env python3
"""savestate — flush in-flight state to today's slate.

Usage:
  python run midstream "<hypothesis>"   # mid-session flush
  python run close "<hypothesis>"       # end-of-session flush + session_capture
"""
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path

IGOR_HOME = Path(os.environ.get("IGOR_HOME", Path.home() / ".unseen_university"))

def _cc_tools() -> Path:
    if val := os.environ.get("CC_WORKFLOW_TOOLS", "").strip():
        return Path(val)
    try:
        from unseen_university._uu_root import uu_root
        return Path(uu_root()) / "lab" / "claudecode"
    except Exception:
        return Path("")

CC_TOOLS = _cc_tools()


def main() -> None:
    mode       = sys.argv[1] if len(sys.argv) > 1 else "midstream"
    hypothesis = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else "NONE"

    date_str = datetime.now().strftime("%Y%m%d")
    slate    = IGOR_HOME / "claudecode" / f"{date_str}.slate.txt"
    slate.parent.mkdir(parents=True, exist_ok=True)

    with slate.open("a", encoding="utf-8") as f:
        f.write(f"\n## In-flight: {hypothesis}\n")

    print(f"savestate ({mode}): {hypothesis}")

    if mode == "close" and CC_TOOLS and CC_TOOLS.exists():
        capture = CC_TOOLS / "session_capture.py"
        if capture.exists():
            result = subprocess.run(
                [sys.executable, str(capture)],
                capture_output=True, text=True
            )
            out = (result.stdout or "").strip()
            if out:
                print(out)
            if result.returncode != 0 and result.stderr:
                print(f"session_capture warning: {result.stderr[:300]}", file=sys.stderr)


if __name__ == "__main__":
    main()
