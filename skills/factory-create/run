#!/usr/bin/env python3
"""factory-create scaffold runner.

Usage:
  python run scaffold --name <slug> --description "<text>" \
                      --owner-id <comms://...> \
                      --members <type1,type2> \
                      --eval-rubric <id|none> \
                      --daily-budget <usd|none>
  python run validate <path/to/factory.yaml>
  python run instantiate <path/to/factory.yaml>
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path


def find_uu_root() -> Path:
    """Locate the UnseenUniversity repo root by scanning upward from CWD."""
    seen: set[Path] = set()
    candidates = [Path.cwd(), *Path.cwd().parents, *Path(__file__).resolve().parents]
    for p in candidates:
        if p in seen:
            continue
        seen.add(p)
        if (p / "devices" / "installer").exists() and (p / "pyproject.toml").exists():
            return p
    raise RuntimeError(
        "Cannot find UnseenUniversity root (no devices/installer/ + pyproject.toml). "
        "Run from the UU repo directory."
    )


def cmd_scaffold(args: argparse.Namespace) -> None:
    uu_root = find_uu_root()
    factories_dir = uu_root / "config" / "factories"
    factories_dir.mkdir(parents=True, exist_ok=True)

    members = [m.strip() for m in args.members.split(",") if m.strip()]
    if not members:
        print("ERROR: --members must be a comma-separated list of agent_type slugs.", file=sys.stderr)
        sys.exit(1)

    daily_budget = None if args.daily_budget.lower() == "none" else float(args.daily_budget)
    eval_rubric = None if args.eval_rubric.lower() == "none" else args.eval_rubric

    member_lines = "\n".join(f"  - agent_type: {m}" for m in members)
    budget_block = (
        f"\nbudget_limits:\n  daily_limit_usd: {daily_budget:.2f}\n"
        if daily_budget is not None
        else ""
    )
    rubric_line = f"\neval_rubric: {eval_rubric}" if eval_rubric else ""

    content = f"""\
# Factory spec — generated by /factory-create scaffold.
# Decision: D-agentic-os-platform-2026-05-30 / T-factory-template
#
# To instantiate:
#   python run validate config/factories/{args.name}.yaml
#   python run instantiate config/factories/{args.name}.yaml

factory_id: {args.name}
factory_version: "1.0"
description: "{args.description}"
status: pending   # pending | approved | active | halted | archived

owner_id: {args.owner_id}     # human today; any comms:// agent tomorrow
orchestrator: granny-pattern  # one agent holds the goal, routes to members

members:
{member_lines}
{rubric_line}
{budget_block}
escalation:
  timeout_secs: 300   # orchestrator escalates to owner after 5 min blocked
  max_retries: 3
"""

    out = factories_dir / f"{args.name}.yaml"
    if out.exists():
        print(f"ERROR: {out} already exists — remove it first.", file=sys.stderr)
        sys.exit(1)

    out.write_text(content)
    print(f"Scaffolded  config/factories/{args.name}.yaml")
    print(f"Owner       {args.owner_id}")
    print(f"Members     {', '.join(members)}")
    print()
    print("Next steps:")
    print(f"  Review    config/factories/{args.name}.yaml")
    print(f"  Validate  python run validate config/factories/{args.name}.yaml")
    print(f"  Approve   set status: approved in the YAML")
    print(f"  Run       python run instantiate config/factories/{args.name}.yaml")


def cmd_validate(args: argparse.Namespace) -> None:
    uu_root = find_uu_root()
    sys.path.insert(0, str(uu_root))

    from devices.installer.factory import load_spec

    path = Path(args.path)
    if not path.is_absolute():
        path = Path.cwd() / path

    try:
        spec = load_spec(path)
        print(f"OK  {path.name}")
        print(f"    factory_id:   {spec.factory_id}")
        print(f"    owner_id:     {spec.owner_id}")
        print(f"    orchestrator: {spec.orchestrator}")
        print(f"    members:      {', '.join(m['agent_type'] for m in spec.members)}")
        print(f"    status:       {spec.status}")
    except ValueError as e:
        print(f"INVALID  {path.name}")
        print(f"  {e}", file=sys.stderr)
        sys.exit(1)


def cmd_instantiate(args: argparse.Namespace) -> None:
    uu_root = find_uu_root()
    sys.path.insert(0, str(uu_root))

    from devices.installer.factory import FactoryInstantiator, load_spec

    path = Path(args.path)
    if not path.is_absolute():
        path = Path.cwd() / path

    spec = load_spec(path)
    if spec.status not in ("approved", "active"):
        print(
            f"WARNING: factory status is {spec.status!r} — expected 'approved'.\n"
            "Set status: approved in the YAML before instantiating in production.\n"
            "Proceeding for preview...",
            file=sys.stderr,
        )

    inst = FactoryInstantiator()
    factory_instance = inst.instantiate(spec)

    print(f"Instantiated  {spec.factory_id}")
    print(f"  status:    {factory_instance.status}")
    print(f"  members:")
    for manifest in factory_instance.member_manifests:
        agent_id = manifest.issued_to.get("agent_id", "?")
        channel_names = [s.name for s in manifest.subscriptions]
        print(f"    {agent_id}  channels={channel_names}")
    print(f"  orchestrator: {factory_instance.orchestrator_address}")
    print(f"  FACTORY_ANNOUNCE posted to {spec.owner_id}")


def main() -> None:
    parser = argparse.ArgumentParser(description="factory-create runner")
    sub = parser.add_subparsers(dest="cmd")

    p_scaffold = sub.add_parser("scaffold", help="Generate a factory YAML spec")
    p_scaffold.add_argument("--name", required=True, help="Factory slug (e.g. 'research-orca')")
    p_scaffold.add_argument("--description", required=True, help="One-sentence description")
    p_scaffold.add_argument(
        "--owner-id", default="comms://akien/", help="comms:// address of the owner"
    )
    p_scaffold.add_argument(
        "--members", required=True, help="Comma-separated agent_type slugs"
    )
    p_scaffold.add_argument(
        "--eval-rubric", default="none", help="Evaluator rubric ID or 'none'"
    )
    p_scaffold.add_argument(
        "--daily-budget", default="none", help="Daily USD limit or 'none'"
    )

    p_validate = sub.add_parser("validate", help="Validate a factory YAML spec")
    p_validate.add_argument("path", help="Path to the factory YAML file")

    p_instantiate = sub.add_parser("instantiate", help="Instantiate a factory spec")
    p_instantiate.add_argument("path", help="Path to the factory YAML file")

    args = parser.parse_args()
    if args.cmd == "scaffold":
        cmd_scaffold(args)
    elif args.cmd == "validate":
        cmd_validate(args)
    elif args.cmd == "instantiate":
        cmd_instantiate(args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
