#!/usr/bin/env python3
"""context-load — FULL session startup (all 10 steps).

Called on resume after compaction. Runs complete context briefing pipeline.
No args — always runs full briefing.
"""
import json
import os
import sys
import subprocess
from datetime import datetime
from pathlib import Path

from unseen_university import slate_store
from unseen_university._uu_root import uu_home, uu_root

IGOR_HOME = Path(uu_home())
# uu_root() resolves UU_ROOT regardless of cwd (env var first, then the package
# __file__ chain). The old get("UU_ROOT", ".") default silently no-op'd the
# decision/memory steps (2a/2b/3) whenever cwd != repo root — e.g. post-compact,
# when context-load is the first thing run and the cwd is wherever the shell landed.
UU_ROOT = Path(uu_root())
CC_WORKFLOW_TOOLS = Path(os.environ.get("CC_WORKFLOW_TOOLS", UU_ROOT / "devlab" / "claudecode"))


# ─── Step 0: Restore CC.x availability (from cachedstate) ───
def step_0_restore_availability() -> None:
    """Restore CC.x availability from cachedstate (file semaphore pattern).

    Extract CC instance from CC_TMUX_SESSION env var (e.g., 'claude-cc.1' → CC.1).
    /savestate moved the flag from ~/.granny/available/ to cachedstate before compact.
    Now restore it if it exists. If cachedstate is empty, CC.x stays unavailable.
    """
    # Detect which CC instance from CC_TMUX_SESSION
    cc_session = os.environ.get("CC_TMUX_SESSION", "claude-main")
    cc_instance = "CC.0"  # default
    if "cc." in cc_session.lower():
        parts = cc_session.lower().split("cc.")
        if len(parts) > 1:
            cc_instance = f"CC.{parts[1].split('.')[0]}"  # e.g., 'cc.1' → 'CC.1'

    granny_avail = Path(os.environ.get("GRANNY_AVAIL_DIR", Path.home() / ".granny" / "available"))
    device_id = cc_instance.lower().replace(".", "_")  # 'CC.1' → 'cc_1'
    cachedstate = IGOR_HOME / "devices" / device_id / "cachedstate"

    granny_avail.mkdir(parents=True, exist_ok=True)

    # Restore from cachedstate if it exists
    if cachedstate.exists():
        for flag_file in cachedstate.glob(f"{cc_instance}.available.*"):
            dest = granny_avail / flag_file.name
            try:
                flag_file.rename(dest)
                print(f"✓ Step 0: {cc_instance} availability restored ({flag_file.name})")
                return
            except Exception:
                pass

    # If no cachedstate file, CC.x stays unavailable (no file = not available)
    print(f"✓ Step 0: {cc_instance} availability (none cached, unavailable)")


# ─── Step 0.25: Stale slate check ───
def step_0_25_stale_slate_check() -> None:
    """Warn if prior-day slate has open items and lacks CLOSED marker."""
    slate_dir = slate_store.slates_dir()
    if not slate_dir.exists():
        return
    today_str = datetime.now().strftime("%Y%m%d")
    slates = sorted(slate_dir.glob("*.slate.txt"))
    for slate_file in reversed(slates):
        date_str = slate_file.name[:8]
        if date_str != today_str:
            content = slate_file.read_text(encoding="utf-8")
            if ("## Next up" in content or "## Blocked" in content) and "✅ CLOSED" not in content:
                print(f"⚠️  STALE SLATE: {slate_file.name} has open items (run /day-close {date_str}?)")
            break


# ─── Step 0.5: Debug flag ───
def step_0_5_debug_flag() -> None:
    """Set debug session flag for observability."""
    flag_dir = IGOR_HOME / "Igor-wild-0001"
    flag_dir.mkdir(parents=True, exist_ok=True)
    (flag_dir / "debug_session.flag").touch()
    print("✓ Step 0.5: Debug flag set")


# ─── Step 1: Today's slate ───
def step_1_today_slate() -> None:
    """Ensure today's slate exists, then read and surface its summary."""
    date_fmt = datetime.now().strftime("%Y-%m-%d")
    slate = slate_store.today_slate_path()
    slate.parent.mkdir(parents=True, exist_ok=True)

    if not slate.exists():
        slate.write_text(
            f"# Slate — {date_fmt}\n\n"
            "## Rewound? (read this if you were rewound, not compacted)\n"
            "A rewind rolls your CONVERSATION back but NOT git/this slate — so "
            "your memory is now BEHIND reality. Read this slate + "
            "`git log --oneline -10`, trust slate+git over your memory, and "
            "`git status` for working-tree divergence (a code-rewind can delete "
            "committed files — `git restore` fixes it) before acting.\n\n"
            "## Summary\n(empty — session just started)\n\n"
            "## Notes\n\n"
            "## In-flight\nNONE\n\n"
            "## Planned\n\n"
            "## Ad hoc\n\n"
            "## Done today\n",
            encoding="utf-8"
        )
        print(f"✓ Step 1: Slate created")
    else:
        # Read and surface the summary for orientation
        content = slate.read_text(encoding="utf-8")
        lines = content.split("\n")
        in_summary = False
        summary_lines = []
        for line in lines:
            if line.startswith("## Summary"):
                in_summary = True
                continue
            if line.startswith("##") and in_summary:
                break
            if in_summary and line.strip():
                summary_lines.append(line.rstrip())

        if summary_lines:
            print(f"✓ Step 1: Slate (today's summary):")
            for line in summary_lines[:5]:  # cap at 5 lines
                print(f"  {line}")
        else:
            print(f"✓ Step 1: Slate ready")


# ─── shared: decisions newest-first by emitted_at ───
def _decisions_newest_first(limit: int) -> list:
    """Return up to `limit` decision records, newest first by emitted_at.

    Sorting by emitted_at (not the filename glob) is load-bearing: the glob
    sorts alphabetically by D-slug, which is NOT chronological — 'recent'
    would surface the alphabetically-last decisions, defeating orientation.
    """
    decisions_dir = UU_ROOT / "devlab" / "runtime" / "memory" / "decisions"
    if not decisions_dir.exists():
        return []
    records = []
    for f in decisions_dir.glob("*.json"):
        try:
            data = json.loads(f.read_text(encoding="utf-8"))
            records.append((data.get("emitted_at", ""), data))
        except Exception:
            pass
    records.sort(key=lambda r: r[0], reverse=True)
    return [data for _, data in records[:limit]]


# ─── Step 2a: Recent decision titles (filesystem store) ───
def step_2a_rules() -> None:
    """Surface the 3 most-recent decisions (by date) for orientation."""
    recent = _decisions_newest_first(3)
    if not recent:
        print("✓ Step 2a: Decisions (none yet)")
        return
    print("✓ Step 2a: Recent decisions:")
    for data in recent:
        namespace = data.get("namespace", [])
        dec_id = namespace[0] if namespace else "?"
        date_str = (data.get("emitted_at", "") or "unknown").split("T")[0]
        print(f"  • {dec_id} ({date_str})")


# ─── Step 2b: Memory structure ───
def step_2b_memory_palace() -> None:
    """Verify filesystem memory structure is accessible."""
    memory_root = UU_ROOT / "devlab" / "runtime" / "memory"
    if memory_root.exists():
        subdirs = [d.name for d in memory_root.iterdir() if d.is_dir()]
        if subdirs:
            print(f"✓ Step 2b: Memory ({', '.join(sorted(subdirs))})")
        else:
            print("✓ Step 2b: Memory structure (empty)")


# ─── Step 3: Active decisions (last 5, with status) ───
def step_3_decisions() -> None:
    """Show the 5 most-recent decisions with their status for orientation."""
    recent = _decisions_newest_first(5)
    if not recent:
        return
    print("✓ Step 3: Active decisions:")
    for data in recent:
        namespace = data.get("namespace", [])
        dec_id = namespace[0] if namespace else "?"
        body = data.get("body", {}) if isinstance(data.get("body"), dict) else {}
        status = body.get("status", "?")
        date_str = (body.get("date") or (data.get("emitted_at", "") or "").split("T")[0]) or "?"
        print(f"  • {dec_id} [{status}] ({date_str})")


# ─── Step 4: Channel (recent posts for context) ───
def step_4_channel() -> None:
    """Load recent channel posts for continuity."""
    try:
        result = subprocess.run(
            [sys.executable, "-c", "from unseen_university.channel import read_recent; read_recent(3)"],
            capture_output=True, text=True, timeout=2
        )
        if result.returncode == 0 and result.stdout.strip():
            print("✓ Step 4: Channel (recent):")
            lines = result.stdout.strip().split("\n")
            for line in lines[:5]:
                if line.strip():
                    print(f"  {line}")
        else:
            print("✓ Step 4: Channel (quiet)")
    except Exception:
        print("✓ Step 4: Channel (offline)")


# ─── Step 5: Queue status (pending approvals — filter out closed) ───
def step_5_pending_approvals() -> None:
    """Check queue for approval-pending tickets, excluding closed ones."""
    try:
        result = subprocess.run(
            [sys.executable, str(CC_WORKFLOW_TOOLS / "cc_queue.py"), "list"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            lines = result.stdout.split("\n")
            # Filter: 🟠 approval pending AND NOT [done/closed]
            pending_tickets = [l for l in lines if "🟠" in l and "[done]" not in l and "[closed]" not in l]
            if pending_tickets:
                print(f"✓ Step 5: Approval pending ({len(pending_tickets)}):")
                for line in pending_tickets[:5]:  # show top 5
                    print(f"  {line.strip()}")
            else:
                print("✓ Step 5: No pending approvals")
    except Exception:
        print("✓ Step 5: Queue (deferred)")


# ─── Step 5.5: Stall check ───
def step_5_5_stall_check() -> None:
    """Flag tickets stuck in_progress >2hrs."""
    try:
        result = subprocess.run(
            [sys.executable, str(CC_WORKFLOW_TOOLS / "stall_check.py")],
            capture_output=True, text=True, timeout=5
        )
        if result.stdout.strip():
            print(f"⚠️  STALLED: {result.stdout.strip()}")
    except Exception:
        pass


# ─── Step 5.6: Unread inbox (urgent/important only) ───
def step_5_6_inbox() -> None:
    """Check CC inbox for unread messages with urgency."""
    try:
        inbox_file = IGOR_HOME / "cc_channel" / "inbox.jsonl"
        if not inbox_file.exists():
            return

        unread = []
        for line in inbox_file.read_text(encoding="utf-8").split("\n"):
            if line.strip() and '"read": false' in line:
                try:
                    entry = json.loads(line)
                    unread.append(entry)
                except Exception:
                    pass

        if not unread:
            return

        # Show unread with urgency flags
        print(f"⚠️  Inbox: {len(unread)} unread")
        high_urgency = [e for e in unread if e.get("urgency") == "high"]
        if high_urgency:
            print(f"  ⚡ URGENT ({len(high_urgency)}):")
            for entry in high_urgency[:3]:
                summary = entry.get("summary", "no subject")
                print(f"    • {summary}")

        granny_posts = [e for e in unread if "granny" in e.get("from", "").lower()]
        if granny_posts:
            print(f"  📮 From Granny ({len(granny_posts)}):")
            for entry in granny_posts[:2]:
                summary = entry.get("summary", "no subject")
                print(f"    • {summary}")
    except Exception:
        pass


# ─── Main: run all steps ───
def main() -> None:
    """Execute full context-load pipeline (10 steps)."""
    print("Loading context...\n")
    try:
        step_0_restore_availability()
        step_0_25_stale_slate_check()
        step_0_5_debug_flag()
        step_1_today_slate()
        step_2a_rules()
        step_2b_memory_palace()
        step_3_decisions()
        step_4_channel()
        step_5_pending_approvals()
        step_5_5_stall_check()
        step_5_6_inbox()
        print("\n✅ Context loaded. Ready to work.")
    except Exception as e:
        print(f"\n❌ Context load error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
