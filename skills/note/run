#!/usr/bin/env python3
"""note — log a milestone, insight, or decision to notes.log and today's slate."""
import os
import sys
from datetime import datetime
from pathlib import Path

from unseen_university import slate_store

IGOR_HOME     = Path(os.environ.get("IGOR_HOME",     Path.home() / ".unseen_university"))
UU_ROOT = Path(os.environ.get("UU_ROOT", Path.home() / "dev/src/UnseenUniversity"))


def main() -> None:
    if len(sys.argv) < 2:
        print("usage: python run <note text> [T-ticket-ids...]", file=sys.stderr)
        sys.exit(1)

    text = " ".join(sys.argv[1:])
    ts   = datetime.now().isoformat(timespec="seconds")
    line = f"{ts} | {text}"

    notes_log = THEIGORS_HOME / "lab" / "notes.log"
    notes_log.parent.mkdir(parents=True, exist_ok=True)
    with notes_log.open("a", encoding="utf-8") as f:
        f.write(line + "\n")

    slate    = slate_store.today_slate_path()
    if slate.exists():
        with slate.open("a", encoding="utf-8") as f:
            f.write(f"\n- note: {text}\n")

    print(line)


if __name__ == "__main__":
    main()
