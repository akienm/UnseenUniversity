#!/usr/bin/env python3
"""migrate-decisions — project decisions from .md to filesystem memory store."""
import subprocess
import sys
import os
from pathlib import Path

# Detect UU_ROOT from env or use default
UU_ROOT = Path(os.environ.get("UU_ROOT", Path.home() / "dev" / "src" / "UnseenUniversity"))
MIGRATOR = UU_ROOT / "devlab" / "claudecode" / "migrate_decisions.py"

if not MIGRATOR.exists():
    print(f"❌ Migrator not found: {MIGRATOR}", file=sys.stderr)
    sys.exit(1)

# Collect args
args = sys.argv[1:]  # Pass through --dry-run or other flags

# Run migration
try:
    result = subprocess.run(
        [sys.executable, str(MIGRATOR)] + args,
        cwd=str(UU_ROOT),
        check=False,
        capture_output=True,
        text=True
    )

    # Print output
    if result.stdout:
        print(result.stdout.rstrip())
    if result.stderr:
        print(result.stderr.rstrip(), file=sys.stderr)

    sys.exit(result.returncode)
except Exception as e:
    print(f"❌ Migration failed: {e}", file=sys.stderr)
    sys.exit(1)
