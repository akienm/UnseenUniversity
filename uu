#!/usr/bin/env python3
"""uu — Unseen University chat launcher.

Bootstraps venv, reads frontend config, then opens a chat interface
connected to Librarian. Any agent can be surfaced the same way by
changing uu.cfg default_frontend.

Usage:
  ./uu                          # use uu.cfg default_frontend (librarian)
  ./uu --frontend=terminal      # force terminal REPL
  ./uu --frontend=web           # open browser to web server UI
  ./uu workflow                 # print the canonical workflow map (skills/workflow.md)
  ./uu --help
"""

import configparser
import os
import subprocess
import sys
from pathlib import Path

UU_ROOT = Path(__file__).resolve().parent
VENV_DIR = UU_ROOT / ".venv"
_BIN = "Scripts" if sys.platform == "win32" else "bin"
_EXT = ".exe" if sys.platform == "win32" else ""
VENV_PYTHON = VENV_DIR / _BIN / f"python{_EXT}"

_RUNTIME_ROOT = Path(os.environ.get("UU_RUNTIME_ROOT") or Path.home() / ".unseen_university")
_GLOBAL_CFG = _RUNTIME_ROOT / "uu.cfg"
_LIBRARIAN_CFG = _RUNTIME_ROOT / "Librarian" / "config.cfg"


# ── Bootstrap ─────────────────────────────────────────────────────────────────


def _bootstrap() -> None:
    if VENV_DIR.exists() and VENV_PYTHON.exists():
        return
    print("uu: first run — bootstrapping venv")
    try:
        subprocess.run(["uv", "venv", str(VENV_DIR)], check=True, cwd=UU_ROOT)
        subprocess.run(
            ["uv", "pip", "install", "--python", str(VENV_PYTHON), "-e", str(UU_ROOT)],
            check=True, cwd=UU_ROOT,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        subprocess.run([sys.executable, "-m", "venv", str(VENV_DIR)], check=True)
        subprocess.run([str(VENV_PYTHON), "-m", "pip", "install", "-e", str(UU_ROOT)], check=True)
    print("uu: bootstrap complete")


# ── Config ────────────────────────────────────────────────────────────────────


def _read_config() -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    cfg.read_dict({"uu": {"default_frontend": "terminal"}})
    for path in (_GLOBAL_CFG, _LIBRARIAN_CFG):
        if path.exists():
            cfg.read(str(path))
    return cfg


def _frontend(cfg: configparser.ConfigParser, override: "str | None") -> str:
    if override:
        return override
    try:
        return cfg.get("uu", "default_frontend")
    except (configparser.NoSectionError, configparser.NoOptionError):
        return "terminal"


# ── Web frontend ──────────────────────────────────────────────────────────────


def _launch_web(cfg: configparser.ConfigParser) -> None:
    port = int(
        os.environ.get("ADC_WEB_PORT")
        or os.environ.get("IGOR_UC_PORT")
        or "8080"
    )
    url = f"http://localhost:{port}/"
    print(f"uu: opening web UI at {url}")
    import webbrowser
    webbrowser.open(url)


# ── Terminal frontend ─────────────────────────────────────────────────────────


def _launch_terminal(cfg: configparser.ConfigParser) -> None:
    """Simple stdin/stdout REPL that routes queries through Librarian's channel."""
    # Try to import channel tooling; degrade gracefully if unavailable.
    try:
        sys.path.insert(0, str(UU_ROOT))
        from lab.claudecode.channel import post_to_channel, read_channel

        def _ask(question: str) -> str:
            post_to_channel("librarian", "uu", f"RECALL:{question}")
            import time
            deadline = time.time() + 10
            while time.time() < deadline:
                msgs = read_channel("librarian", after_ts=time.time() - 0.5)
                for ts, sender, body in (msgs or []):
                    if sender != "uu":
                        return body
                time.sleep(0.5)
            return "(no response from Librarian — is it running?)"

    except ImportError:
        def _ask(question: str) -> str:
            return "(Librarian not available — channel tooling not found)"

    print("uu — Unseen University (Librarian chat)")
    print("Type 'quit' or Ctrl-D to exit.\n")
    while True:
        try:
            line = input("you: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if not line:
            continue
        if line.lower() in ("quit", "exit", "bye"):
            break
        response = _ask(line)
        print(f"librarian: {response}\n")


# ── Main ──────────────────────────────────────────────────────────────────────


def _ensure_granny_running() -> None:
    """Start Granny daemon in background tmux session if not already running."""
    try:
        r = subprocess.run(["tmux", "has-session", "-t", "granny"], capture_output=True)
        if r.returncode != 0:
            granny_script = UU_ROOT / "granny"
            if granny_script.exists():
                subprocess.Popen(
                    [str(VENV_PYTHON), str(granny_script), "--no-attach"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    start_new_session=True,
                )
    except Exception:
        pass  # granny is best-effort; never block uu startup


def _install_skills() -> None:
    """Copy skills/ from the repo to ~/.claude/skills/ (idempotent)."""
    import shutil

    src = UU_ROOT / "skills"
    dst = Path.home() / ".claude" / "skills"
    if not src.exists():
        print("uu bootstrap --skills: no skills/ directory in repo")
        return
    dst.mkdir(parents=True, exist_ok=True)
    count = 0
    for skill_dir in src.iterdir():
        if skill_dir.is_dir():
            dest = dst / skill_dir.name
            shutil.copytree(skill_dir, dest, dirs_exist_ok=True)
            count += 1
    print(f"uu bootstrap --skills: {count} skills installed to {dst}")


def _install_path() -> None:
    """Add UU_ROOT to PATH in ~/.bashrc and ~/.zshrc (idempotent)."""
    marker = f"# UnseenUniversity launchers"
    line = f'export PATH="$PATH:{UU_ROOT}"'
    block = f"\n{marker}\n{line}\n"
    shells = [Path.home() / ".bashrc", Path.home() / ".zshrc"]
    updated = []
    for rc in shells:
        if not rc.exists():
            continue
        content = rc.read_text()
        if str(UU_ROOT) in content:
            print(f"uu bootstrap --path: {rc.name} already has UU_ROOT on PATH — skipped")
            continue
        rc.write_text(content + block)
        updated.append(rc.name)
    if updated:
        print(f"uu bootstrap --path: PATH updated in {', '.join(updated)}")
        print(f"  Added: {line}")
        print("  Reload with: source ~/.bashrc  (or open a new terminal)")
    else:
        print("uu bootstrap --path: PATH already configured in all shell profiles")


def _cmd_contrib(args: list[str]) -> None:
    """uu contrib [scan | list | submit <id>]"""
    sys.path.insert(0, str(UU_ROOT))
    try:
        from devices.archivist.contrib import build_pr_diff, get_staged, list_staged, scan
    except ImportError as e:
        print(f"uu contrib: archivist module unavailable — {e}")
        sys.exit(1)

    subcmd = args[0] if args else "list"

    if subcmd == "scan":
        db_url = os.environ.get(
            "UU_HOME_DB_URL",
            os.environ.get("IGOR_HOME_DB_URL", "postgresql://igor:choose_a_password@127.0.0.1/Igor-wild-0001"),
        )
        staged = scan(db_url=db_url)
        if staged:
            print(f"uu contrib scan: {len(staged)} new candidate(s) staged")
            for r in staged:
                print(f"  {r['id']}: {r['title'][:60]}")
        else:
            print("uu contrib scan: no new candidates above threshold")

    elif subcmd == "list":
        records = list_staged()
        if not records:
            print("uu contrib: staging area empty (run 'uu contrib scan' first)")
        else:
            print(f"uu contrib: {len(records)} staged candidate(s):")
            for r in records:
                print(f"  {r['id']}  hits={r.get('origin_hit_count', '?'):3}  {r['title'][:60]}")

    elif subcmd == "submit" and len(args) > 1:
        contrib_id = args[1]
        record = get_staged(contrib_id)
        if not record:
            print(f"uu contrib submit: '{contrib_id}' not found in staging area")
            sys.exit(1)
        diff = build_pr_diff(record)
        print(diff)

    else:
        print("Usage: uu contrib [scan | list | submit <id>]")
        sys.exit(1)


def _cmd_bootstrap(args: list[str]) -> None:
    """uu bootstrap [--path] [--skills] [--global-kb [<url>]] [--local-kb <path>]"""
    do_kb = "--global-kb" in args or "--local-kb" in " ".join(args)
    if "--path" in args:
        _install_path()
    if "--skills" in args:
        _install_skills()

    if not do_kb and "--path" not in args and "--skills" not in args:
        print("uu bootstrap: nothing to do (try --path, --skills, or --global-kb)")
        return
    if not do_kb:
        return

    kb_url = None
    local_dir = None
    for i, arg in enumerate(args):
        if arg == "--global-kb" and i + 1 < len(args) and not args[i + 1].startswith("-"):
            kb_url = args[i + 1]
        if arg.startswith("--local-kb="):
            local_dir = Path(arg.split("=", 1)[1])
        elif arg == "--local-kb" and i + 1 < len(args):
            local_dir = Path(args[i + 1])

    sys.path.insert(0, str(UU_ROOT))
    try:
        from unseen_university.global_kb import bootstrap

        print(f"uu bootstrap: importing global KB {'from ' + kb_url if kb_url else 'from local dir'}...")
        count = bootstrap(url=kb_url, local_dir=local_dir)
        print(f"uu bootstrap: {count} patterns imported.")
    except Exception as e:
        print(f"uu bootstrap: failed — {e}")
        sys.exit(1)


def _cmd_workflow() -> None:
    """uu workflow — print the canonical workflow map (skills/workflow.md) to the console.

    This is the single source of truth for how the skills fit together; the
    /workflow skill renders the same file. No venv, no chat launch.
    """
    wf = UU_ROOT / "skills" / "workflow.md"
    if not wf.exists():
        print(f"uu workflow: workflow map not found at {wf}", file=sys.stderr)
        sys.exit(1)
    sys.stdout.write(wf.read_text(encoding="utf-8"))


def main() -> None:
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    # `uu workflow` — print the canonical workflow map and exit (no venv / no chat).
    if args and args[0] == "workflow":
        _cmd_workflow()
        return

    # Re-exec under venv python if not already there
    if Path(sys.executable).resolve() != VENV_PYTHON.resolve():
        _bootstrap()
        if VENV_PYTHON.exists():
            os.execv(str(VENV_PYTHON), [str(VENV_PYTHON), __file__] + args)
        # If venv python not available, continue with system python

    # Handle subcommands before parsing frontend flags
    if args and args[0] == "bootstrap":
        _cmd_bootstrap(args[1:])
        return

    if args and args[0] == "contrib":
        _cmd_contrib(args[1:])
        return

    # Parse --frontend flag
    frontend_override = None
    remaining = []
    for arg in args:
        if arg.startswith("--frontend="):
            frontend_override = arg.split("=", 1)[1]
        else:
            remaining.append(arg)

    _ensure_granny_running()

    cfg = _read_config()
    frontend = _frontend(cfg, frontend_override)

    if frontend == "web":
        _launch_web(cfg)
    else:
        _launch_terminal(cfg)


if __name__ == "__main__":
    main()
