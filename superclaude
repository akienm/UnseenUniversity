#!/bin/bash
# superclaude (root) — thin pass-through to the canonical launcher in bin/.
#
# NO logic lives here. All behavior — rack server, venv probing, --1m, --help,
# tmux session handling — is in bin/superclaude. This shim exists only so that
# `./superclaude` at the repo root still works; everything, including --help, is
# forwarded untouched so the bin/ launcher's own flags are authoritative.
# (T-launcher-help-and-1m-flags; supersedes the prior Python delegator, whose
# --help interception shadowed the bin/ launcher's flags.)
exec "$(dirname "$(readlink -f "$0")")/bin/superclaude" "$@"
