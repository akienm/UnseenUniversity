# UnseenUniversity environment variables
# Copy to .env and fill in values — .env is gitignored.

# Postgres connection string for agent-datacenter-0001 (required for DB features)
AGENT_DATACENTER_DB_URL=postgresql://datacenter:<db-password>@127.0.0.1/agent-datacenter-0001

# Docker container name for Postgres lifecycle (default: postgres)
# AGENT_DATACENTER_PG_CONTAINER=postgres
